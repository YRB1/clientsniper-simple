# ──────────────────────────────────────────────
# ClientSniper — Environment Variables
# Copy this file to .env and fill in your values
# Run: python server.py
# ──────────────────────────────────────────────

# Server
PORT=5500

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Stripe Price IDs (create these in your Stripe dashboard)
STRIPE_PRICE_MAPS_MONTHLY=price_REPLACE_ME
STRIPE_PRICE_MAPS_YEARLY=price_REPLACE_ME
STRIPE_PRICE_INSTA_MONTHLY=price_REPLACE_ME
STRIPE_PRICE_INSTA_YEARLY=price_REPLACE_ME
STRIPE_PRICE_BUNDLE_MONTHLY=price_REPLACE_ME
STRIPE_PRICE_BUNDLE_YEARLY=price_REPLACE_ME

# Email (SMTP — works with Gmail, Outlook, SendGrid, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
CONTACT_EMAIL_TO=support@clientsniper.com

# Site URL (for Stripe redirects)
SITE_URL=http://localhost:3000
